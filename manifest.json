{
  "manifest_version": 3,
  "name": "Gemini Chat Organizer",
  "version": "0.2.0",
  "description": "Gemini Webのチャットをタグでグループ分け・フィルタリング",
  "permissions": ["tabs", "storage"],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gemini Chat Organizer"
  },
  "icons": {}
}
